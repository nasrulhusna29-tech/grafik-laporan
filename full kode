<div class="main-layout">
        
        <aside class="sidebar">
            
            <div class="menu-section">
                <label class="menu-label">Menu Utama</label>
                <ul class="side-menu">
                    <li><a href="#" class="active"><span class="icon">📊</span> Data Kunjungan</a></li>
                    <li><a href="#"><span class="icon">📋</span> 10 Besar Penyakit</a></li>
                </ul>
            </div>

            <div class="filter-card">
                <div class="filter-group">
                    <label>Pilih Tahun</label>
                    <select id="tahun" onchange="applyFilters()">
