<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Dashboard Puskesmas - Total Tahunan</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; padding: 20px; text-align: center; }
        .container { background: white; max-width: 1100px; margin: auto; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        .controls { display: flex; justify-content: center; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; align-items: flex-end; }
        .control-group { text-align: left; }
        select { padding: 10px; border-radius: 8px; border: 1px solid #ddd; min-width: 180px; margin-top: 5px; }
        h2 { color: #2c3e50; margin-bottom: 10px; }
        .status-msg { font-size: 14px; color: #3498db; margin-bottom: 10px; height: 20px; }
        .chart-box { position: relative; height: 500px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Analisis Kunjungan Pasien Puskesmas 2025</h2>
    <div id="loading" class="status-msg"></div>
    
    <div class="controls">
        <div class="control-group">
            <label>Pilih Periode Waktu:</label><br>
            <select id="bulan" onchange="loadData()">
                <option value="TOTAL">-- TOTAL SEMUA BULAN --</option>
                <option value="JAN">Januari</option>
                <option value="FEB">Februari</option>
                <option value="MAR">Maret</option>
                <option value="APR">April</option>
                <option value="MEI">Mei</option>
                <option value="JUN">Juni</option>
                <option value="JUL">Juli</option>
                <option value="AGS">Agustus</option>
                <option value="SEP">September</option>
                <option value="OKT">Oktober</option>
                <option value="NOV">November</option>
                <option value="DES">Desember</option>
            </select>
        </div>

        <div class="control-group">
            <label>Filter Nama Poli:</label><br>
            <select id="filterPoli" onchange="applyFilter()">
                <option value="SEMUA">-- Tampilkan Semua Poli --</option>
            </select>
        </div>
    </div>

    <div class="chart-box">
        <canvas id="myChart"></canvas>
    </div>
</div>

<script>
    let chartInstance = null;
    let rawDataStore = [];
    const spreadsheetId = '1PogbrbJAnjpP7NqogqrQbu8WkKs1g62l';
    const daftarBulan = ['JAN', 'FEB', 'MAR', 'APR', 'MEI', 'JUN', 'JUL', 'AGS', 'SEP', 'OKT', 'NOV', 'DES'];

    async function loadData() {
        const selection = document.getElementById('bulan').value;
        const loader = document.getElementById('loading');
        rawDataStore = [];

        if (selection === "TOTAL") {
            loader.innerHTML = "Sedang menjumlahkan data seluruh bulan (Jan-Des)...";
            let agregasiPoli = {};

            // Loop untuk mengambil semua sheet
            for (let b of daftarBulan) {
                const dataBulan = await fetchCSV(b);
                dataBulan.forEach(item => {
                    if (agregasiPoli[item.nama]) {
                        agregasiPoli[item.nama] += item.jml;
                    } else {
                        agregasiPoli[item.nama] = item.jml;
                    }
                });
            }
            // Ubah objek ke array
            for (let poli in agregasiPoli) {
                rawDataStore.push({ nama: poli, jml: agregasiPoli[poli] });
            }
            loader.innerHTML = "Berhasil menampilkan Total Tahunan.";
        } else {
            loader.innerHTML = `Memuat data bulan ${selection}...`;
            rawDataStore = await fetchCSV(selection);
            loader.innerHTML = "";
        }

        updatePoliDropdown();
        applyFilter();
    }

    async function fetchCSV(sheetName) {
        const url = `https://docs.google.com/spreadsheets/d/${spreadsheetId}/gviz/tq?tqx=out:csv&sheet=${sheetName}`;
        try {
            const response = await fetch(url);
            const csvText = await response.text();
            const rows = csvText.split('\n').map(row => {
                const matches = row.match(/(".*?"|[^",\s]+)(?=\s*,|\s*$)/g);
                return matches ? matches.map(m => m.replace(/"/g, "")) : [];
            });

            let listData = [];
            for (let i = 12; i < rows.length; i++) {
                const row = rows[i];
                if (row && row[1] && row[4]) {
                    const nama = row[1].trim();
                    const jml = parseInt(row[4]);
                    if (nama !== "" && !isNaN(jml) && nama !== "NAMA RUANGAN / POLI") {
                        listData.push({ nama, jml });
                    }
                }
            }
            return listData;
        } catch (e) {
            return [];
        }
    }

    function updatePoliDropdown() {
        const filterSelect = document.getElementById('filterPoli');
        const currentVal = filterSelect.value;
        
        // Simpan daftar poli yang unik
        let poliSet = new Set(rawDataStore.map(d => d.nama));
        
        // Reset dropdown kecuali opsi pertama
        filterSelect.innerHTML = '<option value="SEMUA">-- Tampilkan Semua Poli --</option>';
        
        Array.from(poliSet).sort().forEach(poli => {
            const opt = document.createElement('option');
            opt.value = poli;
            opt.innerHTML = poli;
            if (poli === currentVal) opt.selected = true;
            filterSelect.appendChild(opt);
        });
    }

    function applyFilter() {
        const filterValue = document.getElementById('filterPoli').value;
        let filteredData = [...rawDataStore];

        if (filterValue !== "SEMUA") {
            filteredData = rawDataStore.filter(d => d.nama === filterValue);
        }

        filteredData.sort((a, b) => b.jml - a.jml);

        const labels = filteredData.map(d => d.nama);
        const values = filteredData.map(d => d.jml);

        renderChart(labels, values);
    }

    function renderChart(labels, data) {
        const ctx = document.getElementById('myChart').getContext('2d');
        if (chartInstance) chartInstance.destroy();

        chartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels.slice(0, 20),
                datasets: [{
                    label: 'Jumlah Kunjungan Pasien',
                    data: data.slice(0, 20),
                    backgroundColor: '#3498db',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y', // Horizontal agar nama poli terbaca
                plugins: {
                    legend: { display: true }
                }
            }
        });
    }

    // Inisialisasi awal dengan Total
    loadData();
</script>
</body>
</html>
