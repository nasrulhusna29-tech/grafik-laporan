<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Dashboard Puskesmas - Filter Poli</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; padding: 20px; text-align: center; }
        .container { background: white; max-width: 1000px; margin: auto; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        .controls { display: flex; justify-content: center; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
        select { padding: 10px; border-radius: 8px; border: 1px solid #ddd; min-width: 200px; }
        h2 { color: #2c3e50; }
        .chart-box { position: relative; height: 400px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Analisis Kunjungan Pasien Puskesmas 2025</h2>
    
    <div class="controls">
        <div>
            <label>Pilih Bulan: </label><br>
            <select id="bulan" onchange="loadData()">
                <option value="JAN">Januari</option>
                <option value="FEB">Februari</option>
                <option value="MAR">Maret</option>
                <option value="APR">April</option>
                <option value="MEI">Mei</option>
                <option value="JUN">Juni</option>
                <option value="JUL">Juli</option>
                <option value="AGS">Agustus</option>
                <option value="SEP">September</option>
                <option value="OKT">Oktober</option>
                <option value="NOV">November</option>
                <option value="DES">Desember</option>
            </select>
        </div>

        <div>
            <label>Filter Nama Poli: </label><br>
            <select id="filterPoli" onchange="applyFilter()">
                <option value="SEMUA">-- Tampilkan Semua Poli --</option>
            </select>
        </div>
    </div>

    <div class="chart-box">
        <canvas id="myChart"></canvas>
    </div>
</div>

<script>
    let chartInstance = null;
    let rawDataStore = []; // Untuk menyimpan data asli agar filter cepat

    async function loadData() {
        const sheetName = document.getElementById('bulan').value;
        const spreadsheetId = '1PogbrbJAnjpP7NqogqrQbu8WkKs1g62l';
        const url = `https://docs.google.com/spreadsheets/d/${spreadsheetId}/gviz/tq?tqx=out:csv&sheet=${sheetName}`;

        try {
            const response = await fetch(url);
            const csvText = await response.text();
            
            // Parsing CSV
            const rows = csvText.split('\n').map(row => {
                const matches = row.match(/(".*?"|[^",\s]+)(?=\s*,|\s*$)/g);
                return matches ? matches.map(m => m.replace(/"/g, "")) : [];
            });

            rawDataStore = [];
            const poliSet = new Set();

            // Ambil data mulai baris ke-12
            for (let i = 12; i < rows.length; i++) {
                const row = rows[i];
                if (row && row[1] && row[4]) {
                    const nama = row[1].trim();
                    const jml = parseInt(row[4]);
                    if (nama !== "" && !isNaN(jml) && nama !== "NAMA RUANGAN / POLI") {
                        rawDataStore.push({ nama, jml });
                        poliSet.add(nama);
                    }
                }
            }

            // Update Dropdown Poli secara dinamis jika masih kosong
            const filterSelect = document.getElementById('filterPoli');
            if (filterSelect.options.length <= 1) {
                Array.from(poliSet).sort().forEach(poli => {
                    const opt = document.createElement('option');
                    opt.value = poli;
                    opt.innerHTML = poli;
                    filterSelect.appendChild(opt);
                });
            }

            applyFilter();
        } catch (e) {
            console.error(e);
        }
    }

    function applyFilter() {
        const filterValue = document.getElementById('filterPoli').value;
        let filteredData = rawDataStore;

        if (filterValue !== "SEMUA") {
            filteredData = rawDataStore.filter(d => d.nama === filterValue);
        }

        // Urutkan berdasarkan jumlah terbesar
        filteredData.sort((a, b) => b.jml - a.jml);

        const labels = filteredData.map(d => d.nama);
        const values = filteredData.map(d => d.jml);

        renderChart(labels, values);
    }

    function renderChart(labels, data) {
        const ctx = document.getElementById('myChart').getContext('2d');
        if (chartInstance) chartInstance.destroy();

        chartInstance = new Chart(ctx, {
            type: filterPoli.value === "SEMUA" ? 'bar' : 'pie', // Jika satu poli tampilkan Pie/Bar tunggal
            data: {
                labels: labels.slice(0, 15),
                datasets: [{
                    label: 'Jumlah Kunjungan',
                    data: data.slice(0, 15),
                    backgroundColor: [
                        '#3498db', '#e74c3c', '#2ecc71', '#f1c40f', '#9b59b6', '#1abc9c'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: filterPoli.value === "SEMUA" ? { y: { beginAtZero: true } } : { y: { display: false } }
            }
        });
    }

    loadData();
</script>
</body>
</html>
